# JARVIS AI Operating System - Environment Configuration

# ============================================
# API Keys (Required)
# ============================================

# Groq API Key - For LLM inference (DeepSeek, Llama, etc.)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key - For TTS/STT (optional if using Groq for STT)
# Get from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Server Configuration
# ============================================

# Host and Port
HOST=0.0.0.0
PORT=8000

# Debug Mode (true/false)
DEBUG=false

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:19006,http://localhost:3000

# ============================================
# Agent Configuration
# ============================================

# Maximum concurrent tasks
MAX_CONCURRENT_TASKS=5

# Default language (en, hi, hinglish)
DEFAULT_LANGUAGE=en

# Auto-apply to jobs (true/false) - USE WITH CAUTION
AUTO_APPLY=false

# Maximum daily job applications
MAX_DAILY_APPLICATIONS=5

# Minimum match score for auto-apply (0.0 - 1.0)
MIN_MATCH_SCORE=0.7

# ============================================
# Voice Configuration
# ============================================

# Enable voice features
VOICE_ENABLED=true

# STT Provider (whisper, groq)
STT_PROVIDER=whisper

# TTS Provider (openai, elevenlabs)
TTS_PROVIDER=openai

# Default voice ID
DEFAULT_VOICE_ID=alloy

# ============================================
# Memory Configuration
# ============================================

# Short-term memory limit (number of items)
SHORT_TERM_LIMIT=100

# Long-term memory limit (number of items)
LONG_TERM_LIMIT=10000

# Memory decay hours (how long to keep short-term memories)
DECAY_HOURS=24

# Vector embedding dimension
VECTOR_DIMENSION=384

# ============================================
# Freelancing Platform Credentials (Optional)
# ============================================

# Upwork API Credentials
UPWORK_API_KEY=
UPWORK_API_SECRET=

# Fiverr API Credentials
FIVERR_API_KEY=

# Freelancer API Credentials
FREELANCER_API_KEY=

# ============================================
# Email Configuration (Optional)
# ============================================

# SMTP Settings for email automation
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================
# Security Configuration
# ============================================

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_here_change_in_production

# API Rate Limit (requests per minute)
RATE_LIMIT=60

# Permission timeout (seconds)
PERMISSION_TIMEOUT=300

# ============================================
# Monitoring & Logging
# ============================================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log File
LOG_FILE=jarvis.log

# Enable metrics collection
ENABLE_METRICS=true

# ============================================
# Development Settings
# ============================================

# Hot reload (development only)
RELOAD=true

# Reload delay (seconds)
RELOAD_DELAY=1
